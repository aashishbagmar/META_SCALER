from fastapi import FastAPI
from env import TicketRoutingEnv

app = FastAPI()

env = None

@app.post("/reset")
def reset():
    global env
    env = TicketRoutingEnv(task="easy")
    obs = env.reset()
    return {"observation": obs.dict()}

@app.post("/step")
def step(action: dict):
    global env
    obs, reward, done, info = env.step(action)
    return {
        "observation": obs.dict(),
        "reward": reward.value,
        "done": done,
        "info": info
    }

@app.get("/state")
def state():
    return env.state()